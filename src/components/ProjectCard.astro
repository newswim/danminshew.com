---
import { render, type CollectionEntry } from 'astro:content';
import { Image, getImage } from 'astro:assets';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { title, url, purpose, stack, status, images } = project.data;
const { Content } = await render(project);

const gallery = await Promise.all(
  images.map(async (img) => ({
    alt: img.alt,
    src: img.src,
    full: await getImage({ src: img.src, format: 'webp', width: 1920 }),
  }))
);
---

<article class="project">
  {
    gallery.length > 0 && (
      <div class="frames">
        {gallery.map((g) => (
          <a class="thumb" href={g.full.src} aria-label={`View larger: ${g.alt}`}>
            <Image
              src={g.src}
              alt={g.alt}
              widths={[720, 1440]}
              sizes="(max-width: 45rem) 100vw, 42rem"
            />
          </a>
        ))}
      </div>
    )
  }
  <h3>
    {url ? <a href={url}>{title}</a> : title}
    {status && <span class="status">{status}</span>}
  </h3>
  <p class="purpose">{purpose}</p>
  <div class="body">
    <Content />
  </div>
  {stack.length > 0 && <p class="stack">{stack.join(' · ')}</p>}
</article>

<script>
  const dialog = document.createElement('dialog');
  dialog.className = 'lightbox';
  const full = document.createElement('img');
  dialog.append(full);
  document.body.append(dialog);

  document.addEventListener('click', (event) => {
    const thumb = (event.target as Element).closest?.('.frames a.thumb');
    if (thumb instanceof HTMLAnchorElement) {
      event.preventDefault();
      full.src = thumb.href;
      full.alt = thumb.querySelector('img')?.alt ?? '';
      dialog.showModal();
    }
  });

  dialog.addEventListener('click', () => dialog.close());
</script>

<style>
  .project {
    margin-block: var(--space-3);
  }

  .project + .project {
    border-top: 1px solid var(--line);
    padding-top: var(--space-3);
  }

  .frames {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 19rem), 1fr));
    gap: var(--space-2);
    margin-block-end: var(--space-2);
  }

  .thumb {
    line-height: 0;
    cursor: zoom-in;
  }

  .thumb img {
    width: 100%;
    height: auto;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    object-position: top;
    border: 1px solid var(--line);
    border-radius: 8px;
  }

  h3 {
    margin-block: 0 0.15rem;
  }

  .status {
    font-family: var(--font-ui);
    font-size: 0.65em;
    color: var(--faded);
    letter-spacing: 0.05em;
    margin-inline-start: 0.5em;
  }

  .purpose {
    color: var(--faded);
    margin-block-end: var(--space-1);
  }

  .body :global(p:last-child) {
    margin-block-end: 0;
  }

  .stack {
    font-family: var(--font-ui);
    font-size: 0.8em;
    color: var(--faded);
    margin-block: var(--space-1) 0;
  }
</style>
