---
const nav = [
  { href: '/about/', label: 'About' },
  { href: '/work/', label: 'Work' },
  { href: '/projects/', label: 'Projects' },
  { href: '/music/', label: 'Music' },
  { href: '/writing/', label: 'Writing' },
];
const current = Astro.url.pathname;
---

<header>
  <nav aria-label="Site">
    <a class="home" href="/" aria-label="Dan Minshew — home">
      <svg class="mark" viewBox="-30.46 -59.9 67.2 67.2" aria-hidden="true">
        <g>
          <circle cx="0" cy="0" r="4.8"></circle>
          <circle cx="0.73" cy="-10.68" r="4.8"></circle>
          <circle cx="1.39" cy="-20.66" r="4.8"></circle>
          <circle cx="-0.68" cy="-28.58" r="4.03"></circle>
          <circle cx="-4.07" cy="-35.64" r="4.03"></circle>
          <circle cx="-13.63" cy="-41.85" r="3.39"></circle>
          <circle cx="-21.94" cy="-41.04" r="2.84"></circle>
          <circle cx="-3.1" cy="-46.69" r="3.39"></circle>
          <circle cx="-4.92" cy="-54.55" r="2.84"></circle>
          <circle cx="2.33" cy="-49.9" r="2.84"></circle>
          <circle cx="6.16" cy="-26.49" r="4.03"></circle>
          <circle cx="11.67" cy="-29.78" r="4.03"></circle>
          <circle cx="18.31" cy="-37.57" r="3.39"></circle>
          <circle cx="19.18" cy="-45.99" r="2.84"></circle>
          <circle cx="24.61" cy="-39.3" r="2.84"></circle>
          <circle cx="20.91" cy="-28.25" r="3.39"></circle>
          <circle cx="28.2" cy="-29.18" r="2.84"></circle>
          <circle cx="23.59" cy="-22.09" r="2.84"></circle>
        </g>
      </svg>
    </a>
    <ul>
      {
        nav.map((item) => (
          <li>
            <a href={item.href} aria-current={current.startsWith(item.href) ? 'page' : undefined}>
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>

<style>
  header {
    width: min(100% - 2 * var(--space-3), var(--measure));
    margin-inline: auto;
    padding-block: var(--space-3) 0;
  }

  nav {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    flex-wrap: wrap;
    border-bottom: 1px solid var(--line);
    padding-block-end: var(--space-2);
  }

  .home {
    display: inline-flex;
    align-self: center;
  }

  .mark {
    width: 1.75rem;
    height: 1.75rem;
    fill: var(--moss);
    transition: fill 120ms ease;
  }

  .home:hover .mark {
    fill: var(--moss-bright);
  }

  ul {
    display: flex;
    gap: var(--space-2);
    list-style: none;
    margin: 0 0 0 auto;
    padding: 0;
    font-family: var(--font-ui);
    font-size: 0.85em;
  }

  ul a {
    text-decoration: none;
    color: var(--faded);
  }

  ul a:hover,
  ul a[aria-current='page'] {
    color: var(--moss-bright);
  }
</style>
