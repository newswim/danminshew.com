---
const nav = [
  { href: '/about/', label: 'About' },
  { href: '/work/', label: 'Work' },
  { href: '/projects/', label: 'Projects' },
  { href: '/music/', label: 'Music' },
  { href: '/writing/', label: 'Writing' },
];
const current = Astro.url.pathname;
---

<header>
  <nav aria-label="Site">
    <a class="wordmark" href="/">
      <svg class="mark" viewBox="-28.64 -59.05 63.55 63.55" aria-hidden="true">
        <g fill="none" stroke-linecap="round">
          <path d="M0 0 Q0.64 -9.29 1.39 -20.66" stroke-width="5.8"></path>
          <path d="M1.39 -20.66 Q0.45 -27.77 -4.07 -35.64" stroke-width="5.1"></path>
          <path d="M-4.07 -35.64 Q-7.55 -39.4 -13.63 -41.85" stroke-width="4.49"></path>
          <path d="M-13.63 -41.85 Q-17.34 -42.43 -21.94 -41.04" stroke-width="3.95"></path>
          <path d="M-4.07 -35.64 Q-5.22 -40.5 -3.1 -46.69" stroke-width="4.49"></path>
          <path d="M-3.1 -46.69 Q-2.86 -50.31 -4.92 -54.55" stroke-width="3.95"></path>
          <path d="M-3.1 -46.69 Q-1.34 -48.92 2.33 -49.9" stroke-width="3.95"></path>
          <path d="M1.39 -20.66 Q4 -26.26 11.67 -29.78" stroke-width="5.1"></path>
          <path d="M11.67 -29.78 Q15.38 -32.52 18.31 -37.57" stroke-width="4.49"></path>
          <path d="M18.31 -37.57 Q19.52 -41.18 19.18 -45.99" stroke-width="3.95"></path>
          <path d="M18.31 -37.57 Q20.6 -39.41 24.61 -39.3" stroke-width="3.95"></path>
          <path d="M11.67 -29.78 Q15.84 -30.4 20.91 -28.25" stroke-width="4.49"></path>
          <path d="M20.91 -28.25 Q24.18 -27.75 28.2 -29.18" stroke-width="3.95"></path>
          <path d="M20.91 -28.25 Q23.1 -26.16 23.59 -22.09" stroke-width="3.95"></path>
        </g>
      </svg>
      Dan Minshew</a>
    <ul>
      {
        nav.map((item) => (
          <li>
            <a href={item.href} aria-current={current.startsWith(item.href) ? 'page' : undefined}>
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>

<style>
  header {
    width: min(100% - 2 * var(--space-3), var(--measure));
    margin-inline: auto;
    padding-block: var(--space-3) 0;
  }

  nav {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    flex-wrap: wrap;
    border-bottom: 1px solid var(--line);
    padding-block-end: var(--space-2);
  }

  .wordmark {
    display: inline-flex;
    align-items: center;
    gap: 0.45em;
    font-style: italic;
    font-size: var(--size-1);
    text-decoration: none;
  }

  .mark {
    width: 1.1em;
    height: 1.1em;
    stroke: var(--moss);
  }

  ul {
    display: flex;
    gap: var(--space-2);
    list-style: none;
    margin: 0 0 0 auto;
    padding: 0;
    font-family: var(--font-ui);
    font-size: 0.85em;
  }

  ul a {
    text-decoration: none;
    color: var(--faded);
  }

  ul a:hover,
  ul a[aria-current='page'] {
    color: var(--moss-bright);
  }
</style>
