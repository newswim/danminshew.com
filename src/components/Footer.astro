---
import { epigraphs } from '../data/epigraphs';
---

<footer>
  <p class="quiet">
    Austin, Texas · <a href="/rss.xml">RSS</a> · <a href="https://github.com/newswim">GitHub</a>
  </p>
  <p class="quiet"><span id="epigraph">{epigraphs[0]}</span></p>
</footer>

<script is:inline define:vars={{ epigraphs }}>
  const el = document.getElementById('epigraph');
  if (el) el.textContent = epigraphs[Math.floor(Math.random() * epigraphs.length)];
</script>

<style>
  footer {
    width: min(100% - 2 * var(--space-3), var(--measure));
    margin-inline: auto;
    padding-block: var(--space-3);
    border-top: 1px solid var(--line);
    display: flex;
    justify-content: space-between;
    gap: var(--space-2);
    flex-wrap: wrap;
    font-family: var(--font-ui);
  }

  p {
    margin: 0;
  }

  #epigraph {
    font-style: italic;
  }
</style>
