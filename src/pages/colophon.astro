---
import Base from '../layouts/Base.astro';
import { epigraphs } from '../data/epigraphs';
---

<Base title="Colophon" description="How this site is built, and why the footer says what it says.">
  <h1>Colophon</h1>

  <h2>The word in the footer</h2>
  <p>
    <em>riverrun</em> is the first word of <em>Finnegans Wake</em> — lowercase, mid-stream,
    the book's final sentence flowing back into its first. A river that keeps going.
  </p>
  <p>
    It shares the footer with a small, slowly growing collection of words and phrases — one
    surfaces each visit. A commonplace-book habit, moved outdoors. The current collection:
  </p>
  <ul>
    {epigraphs.map((phrase) => <li><em>{phrase}</em></li>)}
  </ul>

  <h2>How this site is built</h2>
  <p>
    <a href="https://astro.build">Astro</a> and TypeScript, plain CSS, content as markdown.
    Static output, deployed on Vercel. No trackers, no frameworks, no feeds — fast, accessible,
    and owned. For the machines: <a href="/llms.txt">llms.txt</a>. For the people:
    <a href="/humans.txt">humans.txt</a>.
  </p>
</Base>
