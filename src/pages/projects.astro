---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';

const all = await getCollection('projects');
const section = (name: 'building' | 'civic') =>
  all.filter((p) => p.data.section === name).sort((a, b) => a.data.order - b.data.order);

const building = section('building');
const civic = section('civic');
---

<Base title="Projects" description="Things Dan Minshew has built and is building — apps, civic tech, community work.">
  <h1>Projects</h1>

  <h2>Building</h2>
  {building.map((project) => <ProjectCard project={project} />)}

  <h2>Civic &amp; community</h2>
  {civic.map((project) => <ProjectCard project={project} />)}
</Base>
