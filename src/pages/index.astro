---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import PersonJsonLd from '../components/PersonJsonLd.astro';

const posts = (await getCollection('writing', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const fmt = new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'short', timeZone: 'UTC' });
---

<Base>
  <PersonJsonLd slot="head" />
  <h1>Dan Minshew</h1>
  <p>
    Software engineer and musician in Austin, Texas. I build things for the web, play in
    <a href="https://pryband.bandcamp.com">Pry</a>, and think a lot about living systems — code,
    land, sound, attention.
  </p>
  <p class="quiet">
    This site is a home base outside the feeds: <a href="/work/">work</a>,
    <a href="/projects/">projects</a>, <a href="/music/">two decades of bands</a>, and
    <a href="/writing/">writing</a>.
  </p>

  {
    posts.length > 0 && (
      <>
        <h2>Recent writing</h2>
        <ul class="entry-list">
          {posts.map((post) => (
            <li>
              <a href={`/writing/${post.id}/`}>{post.data.title}</a>
              <time datetime={post.data.date.toISOString()}>{fmt.format(post.data.date)}</time>
            </li>
          ))}
        </ul>
      </>
    )
  }
</Base>
